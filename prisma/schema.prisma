generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  name           String?
  displayName    String?
  avatarSeed     String         @default(cuid())
  bio            String?
  emailVerified  Boolean        @default(false)
  isAdmin        Boolean        @default(false)
  currentStreak  Int            @default(0)
  longestStreak  Int            @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime       @default(now())
  submissions    Submission[]
  votes          Vote[]
  reports        Report[]
  sealProgress   SealProgress[]
  tokens         Token[]
}

model Token {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String
  type      String   // "email_verify" | "password_reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([hash, type])
}

model SealProgress {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sealSlug String
  score    Int    @default(0)
  level    Int    @default(0)

  @@unique([userId, sealSlug])
  @@index([userId])
}

model Submission {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflection String
  createdAt  DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  verses      SubmissionVerse[]
  votes       Vote[]
  reports     Report[]
  submissionBadges SubmissionBadge[]

  @@index([userId])
  @@index([createdAt])
}

model Badge {
  id        String            @id @default(cuid())
  slug      String            @unique
  label     String
  tagline   String
  variant   String
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  submissions SubmissionBadge[]
}

model SubmissionBadge {
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  badgeId      String
  badge        Badge      @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([submissionId, badgeId])
  @@index([badgeId])
}

model Report {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reporterId   String
  reporter     User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason       String
  status       String     @default("open") // "open" | "dismissed" | "actioned"
  adminNote    String?
  resolvedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@unique([submissionId, reporterId])
  @@index([submissionId])
  @@index([status])
}

model SubmissionVerse {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  surah        Int
  ayah         Int

  @@unique([submissionId, surah, ayah])
  @@index([surah, ayah])
}

model Vote {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  value        Int

  @@unique([userId, submissionId])
  @@index([submissionId])
}
