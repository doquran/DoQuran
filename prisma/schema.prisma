generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String?
  createdAt    DateTime     @default(now())
  submissions  Submission[]
  votes        Vote[]
  reports      Report[]
}

model Submission {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflection String
  createdAt  DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  verses      SubmissionVerse[]
  votes       Vote[]
  reports     Report[]

  @@index([userId])
  @@index([createdAt])
}

model Report {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reporterId   String
  reporter     User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason       String
  createdAt    DateTime   @default(now())

  @@unique([submissionId, reporterId])
  @@index([submissionId])
}

model SubmissionVerse {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  surah        Int
  ayah         Int

  @@unique([submissionId, surah, ayah])
  @@index([surah, ayah])
}

model Vote {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  value        Int

  @@unique([userId, submissionId])
  @@index([submissionId])
}
