# === Database ===
# Neon Postgres (recommended): https://neon.tech — use the pooled connection string
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# Local dev with SQLite: change prisma/schema.prisma provider to "sqlite"
# DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://user:pass@localhost:5432/doquran"

# === Auth ===
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="generate-a-secure-random-string"

# === Email (Resend) ===
# Get your API key at https://resend.com — emails log to console when not set
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# MAIL_FROM="DoQuran <noreply@doquran.app>"

# === Rate limiting (Upstash Redis) ===
# Get credentials at https://upstash.com — falls back to in-memory when not set
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXxx..."

# === Error monitoring (Sentry) ===
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxx.ingest.sentry.io/xxx"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="doquran"

# === Content moderation (OpenAI) ===
# The moderation endpoint is free (no token cost). Get a key at https://platform.openai.com
# OPENAI_API_KEY="sk-..."

# === App ===
# NEXT_PUBLIC_BASE_URL="https://doquran.app"
# RATE_LIMIT_DISABLED="true"  # set in local tests to bypass rate limits
